# ============================================
# Keep these (They are essential)
# ============================================
!requirements.txt
!README.md
!LICENSE
!CODE_OF_CONDUCT.md

# Keep model folder structure but not large files
!MODEL_HANGAR/
MODEL_HANGAR/*.json
!MODEL_HANGAR/*.json

# Keep assets but not generated images
!assets/
!assets/icons/
!assets/css/